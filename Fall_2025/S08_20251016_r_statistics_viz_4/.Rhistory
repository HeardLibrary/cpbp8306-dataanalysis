"Northwestern", "Hybrid", 515,590,819,1057,1173,1122,
"Northwestern", "None", 4031,4244,3983,3941,5114,5182,
"Vanderbilt", "Total", 7609,8403,8223,8162,8210,6848,
"Vanderbilt", "Bronze", 1201,1225,798,591,227,124,
"Vanderbilt", "Gold", 1614,1950,2035,2117,2103,1440,
"Vanderbilt", "Green", 1649,1841,1739,1628,980,297,
"Vanderbilt", "Hybrid", 420,498,567,712,1149,1263,
"Vanderbilt", "None", 2725,2889,3084,3114,3751,3724
)
# Convert to long format
data_long <- data %>%
pivot_longer(cols = `2020`:`2025`, names_to = "Year", values_to = "Count") %>%
mutate(Year = as.integer(Year))
# Calculate proportions (exclude totals)
data_prop <- data_long %>%
group_by(Institution, Year) %>%
mutate(Total = Count[OA == "Total"]) %>%
ungroup() %>%
filter(OA != "Total") %>%
mutate(Proportion = Count / Total)
# Plot
ggplot(data_prop, aes(x = Year, y = Proportion, color = OA)) +
geom_line(size = 1.1) +
facet_wrap(~Institution) +
scale_y_continuous(labels = scales::percent_format(accuracy = 1)) +
labs(
title = "Proportion of OA Categories by Institution (2020–2025)",
x = "Year",
y = "Proportion of Total Output",
color = "OA Type"
) +
theme_minimal(base_size = 14) +
theme(legend.position = "bottom")
View(data)
data_prop
View(data_prop)
