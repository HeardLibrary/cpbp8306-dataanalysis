axis.text.x = element_text(angle = 0)  # Rotate x-axis text for readability
) +
scale_fill_brewer(palette = "Set2")  +
scale_y_continuous(limits = c(0, 15), breaks = c(0, 5, 10, 15)) +
guides(fill = guide_legend(ncol = 1))
ggsave(verification_time_plot, filename = "~/Desktop/verification_practices_over_time.png", width = 10, height = 6)
# Create the stacked bar chart
verification_time_plot <- ggplot(data_long, aes(x = Year, y = Count, fill = Verification_Practice)) +
geom_bar(stat = "identity", position = "stack") +  # Ensure bars are stacked
labs(x = "Season & Year", y = "Count", fill = "Verification Practice") +
theme_minimal() +
theme(
panel.background = element_rect(fill = "white", color = NA),  # Set panel background to white
plot.background = element_rect(fill = "white", color = NA),   # Set plot background to white
text = element_text(size = 12),
legend.title = element_text(size = 12),
legend.position = c(0.3, 0.68),
#legend.position = "right",
legend.justification = c("right", "bottom"),
legend.text = element_text(size = 9),  # Increase legend text size
legend.title.position = "top",
axis.text.x = element_text(angle = 0)  # Rotate x-axis text for readability
) +
scale_fill_brewer(palette = "Set2")  +
scale_y_continuous(limits = c(0, 15), breaks = c(0, 5, 10, 15)) +
guides(fill = guide_legend(ncol = 1))
ggsave(verification_time_plot, filename = "~/Desktop/verification_practices_over_time.png", width = 10, height = 6)
